@isTest
public class StaleLeadProcessingBatchTest {

    @TestSetup
    static void setupData() {
        List<Lead> leads = new List<Lead>();

        // High score lead -> should convert (corporate email + company + matching industry assumed via metadata)
        Lead l1 = new Lead(
            LastName = 'HighScore',
            Company = 'Acme Corp',
            Email = 'contact@acmecorp.com',
            Industry = 'Healthcare',
            Status = 'Open - Not Contacted'
        );
        leads.add(l1);

        // Low score lead -> should be disqualified (free email, no company, no matching industry)
        Lead l2 = new Lead(
            LastName = 'LowScore',
            Company = 'ASD',
            Email = 'someone@gmail.com',
            Industry = 'Unknown',
            Status = 'Open - Not Contacted'
            
        );
        leads.add(l2);

        // Medium score lead -> below threshold (corporate email + company = 25) -> disqualified
        Lead l3 = new Lead(
            LastName = 'MediumScore',
            Company = 'Beta LLC',
            Email = 'info@betallc.com',
            Industry = 'Unknown',
            Status = 'Open - Not Contacted'
        );
        leads.add(l3);

        insert leads;

        // Manually backdate CreatedDate is not directly possible via DML;
        // Use Test.setCreatedDate to simulate old leads
        Test.setCreatedDate(l1.Id, DateTime.now().addDays(-100));
        Test.setCreatedDate(l2.Id, DateTime.now().addDays(-120));
        Test.setCreatedDate(l3.Id, DateTime.now().addDays(-95));
    }

    @isTest
    static void testBatchExecution() {
        Test.startTest();
        StaleLeadProcessingBatch batch = new StaleLeadProcessingBatch(200);
        Database.executeBatch(batch, 200);
        Test.stopTest();

        List<Lead> remainingLeads = [SELECT Id, Status, IsConverted FROM Lead];

        // At least confirm some leads were disqualified
        Integer disqualifiedCount = 0;
        for (Lead ld : remainingLeads) {
            if (ld.Status == 'Disqualified') {
                disqualifiedCount++;
            }
        }
    }

    @isTest
    static void testDefaultConstructor() {
        StaleLeadProcessingBatch batch = new StaleLeadProcessingBatch();
    }

    @isTest
    static void testCustomBatchSizeConstructor() {
        StaleLeadProcessingBatch batch = new StaleLeadProcessingBatch(50);
    }

    @isTest
    static void testScheduler() {
        Test.startTest();
        String cronExp = '0 0 1 * * ?';
        String jobId = System.schedule(
            'Stale Lead Batch Test Job',
            cronExp,
            new StaleLeadProcessingScheduler()
        );
        Test.stopTest();

        CronTrigger ct = [
            SELECT Id, CronExpression, TimesTriggered, NextFireTime
            FROM CronTrigger
            WHERE Id = :jobId
        ];
    }

    @isTest
    static void testFinishEmailSummary() {
        // This implicitly tests finish() since executeBatch triggers start->execute->finish
        Test.startTest();
        Database.executeBatch(new StaleLeadProcessingBatch(), 200);
        Test.stopTest();
    }
}

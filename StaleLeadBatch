public class StaleLeadProcessingBatch implements Database.Batchable<SObject>, Database.Stateful {

    // Configurable batch size, default 200
    public Integer batchSize = 200;

    // Stateful tracking variables
    public Integer totalProcessed = 0;
    public Integer totalConverted = 0;
    public Integer totalDisqualified = 0;
    public List<String> failedRecords = new List<String>();

    // Constructor - default batch size
    public StaleLeadProcessingBatch() {
        this.batchSize = 200;
    }

    // Constructor - configurable batch size
    public StaleLeadProcessingBatch(Integer batchSize) {
        this.batchSize = batchSize != null && batchSize > 0 ? batchSize : 200;
    }

    // ---------------- START ----------------
    public Database.QueryLocator start(Database.BatchableContext bc) {
        DateTime ninetyDaysAgo = DateTime.now().addDays(-90);

        String query = 'SELECT Id, Email, Company, Industry, Status, ' +
                        'CreatedDate, LastActivityDate, IsConverted ' +
                        'FROM Lead ' +
                        'WHERE IsConverted = false ' +
                        'AND CreatedDate <= :ninetyDaysAgo ' +
                        'AND LastActivityDate = null';

        return Database.getQueryLocator(query);
    }

    // ---------------- EXECUTE ----------------
    public void execute(Database.BatchableContext bc, List<Lead> scope) {

        // Free email domains - everything else treated as "corporate"
        Set<String> freeDomains = new Set<String>{
            'gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'aol.com', 'icloud.com'
        };

        // Load valid industries from Custom Metadata
        Set<String> validIndustries = new Set<String>();
        for (Lead_Industry_Config__mdt cfg : Lead_Industry_Config__mdt.getAll().values()) {
            if (cfg.Industry_Name__c != null) {
                validIndustries.add(cfg.Industry_Name__c.trim().toLowerCase());
            }
        }

        List<Lead> leadsToConvert = new List<Lead>();
        List<Database.LeadConvert> leadConverts = new List<Database.LeadConvert>();
        List<Lead> leadsToDisqualify = new List<Lead>();

        // Default lead status for conversion (org-specific - adjust as needed)
        LeadStatus convertedStatus = [
            SELECT MasterLabel FROM LeadStatus WHERE IsConverted = true LIMIT 1
        ];

        for (Lead ld : scope) {
            totalProcessed++;
            Integer score = 0;

            // Rule 1: Corporate email domain
            if (String.isNotBlank(ld.Email) && ld.Email.contains('@')) {
                String domain = ld.Email.substringAfter('@').toLowerCase();
                if (!freeDomains.contains(domain)) {
                    score += 10;
                }
            }

            // Rule 2: Industry exists in Custom Metadata
            if (String.isNotBlank(ld.Industry) &&
                validIndustries.contains(ld.Industry.trim().toLowerCase())) {
                score += 20;
            }

            // Rule 3: Company populated
            if (String.isNotBlank(ld.Company)) {
                score += 15;
            }

            // Decision logic
            if (score >= 30) {
                Database.LeadConvert lc = new Database.LeadConvert();
                lc.setLeadId(ld.Id);
                lc.setConvertedStatus(convertedStatus.MasterLabel);
                lc.setDoNotCreateOpportunity(false);
                leadConverts.add(lc);
            } else {
                ld.Status = 'Disqualified';
                leadsToDisqualify.add(ld);
            }
        }

        // Convert qualifying leads
        if (!leadConverts.isEmpty()) {
            List<Database.LeadConvertResult> convertResults =
                Database.convertLead(leadConverts, false);

            for (Integer i = 0; i < convertResults.size(); i++) {
                Database.LeadConvertResult res = convertResults[i];
                if (res.isSuccess()) {
                    totalConverted++;
                } else {
                    failedRecords.add('LeadConvert [' + leadConverts[i].getLeadId() + ']: ' +
                                       res.getErrors()[0].getMessage());
                }
            }
        }

        // Disqualify non-qualifying leads
        if (!leadsToDisqualify.isEmpty()) {
            List<Database.SaveResult> saveResults =
                Database.update(leadsToDisqualify, false);

            for (Integer i = 0; i < saveResults.size(); i++) {
                Database.SaveResult res = saveResults[i];
                if (res.isSuccess()) {
                    totalDisqualified++;
                } else {
                    failedRecords.add('LeadUpdate [' + leadsToDisqualify[i].Id + ']: ' +
                                       res.getErrors()[0].getMessage());
                }
            }
        }
    }

    // ---------------- FINISH ----------------
    public void finish(Database.BatchableContext bc) {

        AsyncApexJob job = [
            SELECT Id, Status, NumberOfErrors, JobItemsProcessed,
                   TotalJobItems, CreatedBy.Email
            FROM AsyncApexJob
            WHERE Id = :bc.getJobId()
        ];

        String body = 'Stale Lead Processing Engine - Batch Summary\n\n';
        body += 'Total Leads Processed   : ' + totalProcessed + '\n';
        body += 'Total Leads Converted    : ' + totalConverted + '\n';
        body += 'Total Leads Disqualified : ' + totalDisqualified + '\n';
        body += 'Total Failures           : ' + failedRecords.size() + '\n\n';

        if (!failedRecords.isEmpty()) {
            body += 'Failure Details:\n';
            for (String err : failedRecords) {
                body += '- ' + err + '\n';
            }
        }

        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setToAddresses(new String[] { job.CreatedBy.Email });
        mail.setSubject('Stale Lead Batch Job Summary - ' + Date.today().format());
        mail.setPlainTextBody(body);

        Messaging.sendEmail(new Messaging.SingleEmailMessage[] { mail });
    }
}
